APP_NAME=Tendr
ENVIRONMENT=development
DEBUG=true

# SQLite (dev) — Docker shart emas. Ishga tushirish: alembic upgrade head
DATABASE_URL=sqlite+aiosqlite:///./tendr.db
SYNC_DATABASE_URL=sqlite:///./tendr.db

# Production'da Postgres'ga o'tish uchun:
# DATABASE_URL=postgresql+asyncpg://tendr:tendr_dev@localhost:5432/tendr
# SYNC_DATABASE_URL=postgresql+psycopg://tendr:tendr_dev@localhost:5432/tendr

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

REDIS_URL=redis://localhost:6379/0

YANDEX_MAPS_API_KEY=
